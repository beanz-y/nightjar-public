# Force LF for every text file so a build is byte-identical across OSes
# (DESIGN 10, a should-fix from the P7 red-team). The operator works on
# Windows; without this, git would check text out with CRLF locally while Linux
# CI/Docker use LF, and a Windows friend rebuilding from a public tag would get a
# different release hash than the LF-built one signed into Rekor. Reproduction
# requires an LF checkout (the runbook says so).
* text=auto eol=lf

# Binary assets: never touch their bytes.
*.png binary
*.ico binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.woff binary
*.woff2 binary
